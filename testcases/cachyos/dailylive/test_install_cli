# Install CachyOS using CLI installer in headless mode

function test_description() {
    cat << EOF
Do a clean install of CachyOS using the CLI installer (headless mode)
EOF
}

function test_setup() {
    test_user="cachyos"
    test_password="ILoveCandy"
}

function qt_wait_else() {
    local test_name="$1"
    local fallback="$2"
    local text="$3"
    local retries=$4
    local interval=$5

    for c in $( seq 1 $retries ); do
        qt_echo "🔁 $c / $retries «$text» "
        qt_screenshot_ppm "$test_name"
        if qt_search_screenshot "$test_name" "$text"; then
            return 0
        fi
        qt_wait_for_seconds "$interval"
    done

    "$fallback" "$test_name"

    qt_test_fail "Couldn't find text «$text» in screenshot «$QT_SCREENSHOT_COUNT» after $retries retries"
}

function test_post_boot_grub() {
    qt_wait_for_seconds 5
    qt_wait_for_text "$FUNCNAME" "GNU GRUB" 3 5
    qt_screenshot_ppm "$FUNCNAME"
    qt_send_key "return"
}

function test_wait_for_desktop() {
    qt_wait_for_text "$FUNCNAME" "$text_console_prompt_welcome" 3 60
    qt_screenshot_ppm "$FUNCNAME"
}

function test_open_terminal() {
    qt_send_key_combo "alt-f2"
    qt_wait_for_seconds 2
    qt_send_string_tab "konsole"
    qt_send_key "return"
    qt_wait_for_seconds 3
    qt_screenshot_ppm "$FUNCNAME"
}

function test_generate_config_and_install() {
    local bootloader="${TEST_BOOTLOADER:-grub}"
    local filesystem="${TEST_FILESYSTEM:-btrfs}"

    # Run the config generator script (already on ISO) and then the installer
    # The script reads TEST_BOOTLOADER and TEST_FILESYSTEM env vars
    qt_send_string_tab "TEST_BOOTLOADER=$bootloader TEST_FILESYSTEM=$filesystem generate-installer-config.sh"
    qt_send_key "return"
    qt_wait_for_seconds 2
    qt_screenshot_ppm "$FUNCNAME"

    # Run the installer
    qt_send_string_tab "sudo cachyos-installer"
    qt_send_key "return"
    qt_screenshot_ppm "$FUNCNAME"
}

function test_installer_failed() {
    qt_screenshot_ppm "$FUNCNAME"
}

function test_wait_for_completion() {
    # Wait for installer to finish (up to 30 min for package download/install)
    # The installer prints a summary box containing "Your device:" on completion,
    # then shows "Close installer?" and "save the installation-log" TUI dialogs
    qt_wait_else "$FUNCNAME" "test_installer_failed" "$text_cli_install_summary" 30 60
    qt_screenshot_ppm "$FUNCNAME"

    # Dismiss "Close installer?" dialog (Enter = yes)
    qt_wait_for_seconds 2
    qt_send_key "return"
    qt_wait_for_seconds 2
    # Dismiss "save log?" dialog (Enter = yes)
    qt_send_key "return"
    qt_wait_for_seconds 2
    qt_screenshot_ppm "$FUNCNAME"
}

function test_power_off_vm() {
    qt_poweroff_vm
}

function test_input_validation() {
    local -Ar bootloaders=(["grub"]=1 ["refind"]=1 ["systemd-boot"]=1 ["limine"]=1)
    local -Ar filesystems=(["btrfs"]=1 ["xfs"]=1 ["ext4"]=1 ["f2fs"]=1 ["zfs"]=1)

    local bootloader="${TEST_BOOTLOADER:-grub}"
    [ -z "${bootloaders[$bootloader]+x}" ] && { qt_echo "🚨 Unknown bootloader: $bootloader"; exit 1; }
    qt_echo "✅ Bootloader: $bootloader"

    local filesystem="${TEST_FILESYSTEM:-btrfs}"
    [ -z "${filesystems[$filesystem]+x}" ] && { qt_echo "🚨 Unknown filesystem: $filesystem"; exit 1; }
    qt_echo "✅ Filesystem: $filesystem"
}

function test_install_cli() {
    test_input_validation
    test_setup
    test_post_boot_grub
    test_wait_for_desktop
    test_open_terminal
    test_generate_config_and_install
    test_wait_for_completion
    test_power_off_vm
}

test_description
